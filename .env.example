# ─────────────────────────────────────
# Integration Service
# ─────────────────────────────────────
PORT=3001
HOST=0.0.0.0
JWT_SECRET=super-secret-key-change-me

# ─────────────────────────────────────
# Actual Budget Configuration
# When using docker-compose, ACTUAL_SERVER_URL is overridden
# to http://actual-server:5006 automatically.
# ─────────────────────────────────────
ACTUAL_SERVER_URL=http://actual-server:5006
ACTUAL_PASSWORD=your-actual-password
ACTUAL_SYNC_ID=your-budget-sync-id
ACTUAL_DATA_DIR=./budget-data

# ─────────────────────────────────────
# Docker Compose (optional overrides)
# ─────────────────────────────────────
# ACTUAL_PORT=5006
